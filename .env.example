# Application
APP_NAME=GradeAI
APP_ENV=development
# Allowed: development | production | test
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
DATABASE_URL=postgresql+asyncpg://gradeai:gradeai@postgres:5432/gradeai
DATABASE_URL_SYNC=postgresql://gradeai:gradeai@postgres:5432/gradeai

# Redis
REDIS_URL=redis://redis:6379/0

# ChromaDB
CHROMADB_HOST=chromadb
CHROMADB_PORT=8000

# JWT / Auth
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_MODEL=gemini-2.0-flash

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=gradeai-uploads
AWS_S3_ENDPOINT=

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Frontend (build-time / Vite)
VITE_API_BASE_URL=http://localhost/api/v1

# Nginx
NGINX_PORT=80

# Postgres (docker-compose)
POSTGRES_USER=gradeai
POSTGRES_PASSWORD=gradeai
POSTGRES_DB=gradeai
